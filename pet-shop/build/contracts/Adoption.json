  "source": "pragma solidity >=0.5.0 <0.7.0;\n\ncontract Adoption {\n  //狗狗 总地址数组\n  address [16] public adoptions;\n\n  function adopt(uint petId) public returns (uint){\n    require(petId >=0 && petId <=15);\n    adoptions[petId] = msg.sender;\n    return petId;\n  }\n\n  function getAdoptions() public returns (address[16] memory){\n\n  return adoptions;\n  }\n\n}",
